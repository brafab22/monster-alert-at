{
  "name": "monster-alert-at",
  "version": "1.0.0",
  "description": "Monitors Monster Energy prices on Austrian supermarket websites and sends push notifications on sale",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "check": "node src/index.js --check-now",
    "dry-run": "node src/index.js --dry-run --check-now",
    "summary": "node src/index.js --summary-now",
    "summary-dry-run": "node src/index.js --dry-run --summary-now"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.44.1"
  }
}
