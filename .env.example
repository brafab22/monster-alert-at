NTFY_TOPIC=monster-alert-austria-YOUR_RANDOM_STRING
PRICE_THRESHOLD_EUR=1.49
CHECK_INTERVAL_HOURS=2

# Hour of day (0-23, server local time) to send the daily price-list summary
DAILY_SUMMARY_HOUR=9

# Optional: ADEG has no national flyer. Pick your local market on
# https://www.adeg.at/flugblatt-aktionen/adeg-flugblatt, then paste the
# resulting flyer-viewer URL here to enable the best-effort ADEG flyer scan.
# Leave empty to skip ADEG entirely.
ADEG_MARKT_URL=
